(kicad_pcb
  (version 20221018)
  (generator "codex")
  (general
    (thickness 1.6))
  (paper "A3")
  (title_block
    (title "Forest Surveillance Rover Main Controller PCB")
    (company "Team Onyx India")
    (rev "A")
    (comment 1 "Layout floorplan with named nets")
    (comment 2 "Board target approximately 100mm x 80mm"))
  (layers
    (0 "F.Cu" signal)
    (31 "B.Cu" signal)
    (32 "B.Adhes" user)
    (33 "F.Adhes" user)
    (34 "B.Paste" user)
    (35 "F.Paste" user)
    (36 "B.SilkS" user)
    (37 "F.SilkS" user)
    (38 "B.Mask" user)
    (39 "F.Mask" user)
    (40 "Dwgs.User" user)
    (41 "Cmts.User" user)
    (44 "Edge.Cuts" user)
    (45 "Margin" user)
    (46 "B.CrtYd" user)
    (47 "F.CrtYd" user)
    (48 "B.Fab" user)
    (49 "F.Fab" user)
    (4 "In1.Cu" power)
    (5 "In2.Cu" power))
  (setup
    (pad_to_mask_clearance 0)
    (stackup
      (layer "F.Cu" (type "copper") (thickness 0.035))
      (layer "dielectric 1" (type "prepreg") (thickness 0.18) (material "FR4"))
      (layer "In1.Cu" (type "copper") (thickness 0.035))
      (layer "dielectric 2" (type "core") (thickness 1.10) (material "FR4"))
      (layer "In2.Cu" (type "copper") (thickness 0.035))
      (layer "dielectric 3" (type "prepreg") (thickness 0.18) (material "FR4"))
      (layer "B.Cu" (type "copper") (thickness 0.035))
      (copper_finish "ENIG")
      (dielectric_constraints yes))
    (pcbplotparams
      (layerselection 0x00010fc_ffffffff)
      (plot_on_all_layers_selection 0x0000000_00000000)
      (disableapertmacros false)))
  (property "StackupIntent" "Signal-GND-Power-Signal")
  (property "LayoutStatus" "Preliminary floorplan")
  (net 0 "")
  (net 1 "VBAT")
  (net 2 "+5V")
  (net 3 "+3V3")
  (net 4 "MOTOR_VBAT")
  (net 5 "GND")
  (net 6 "I2C1_SCL")
  (net 7 "I2C1_SDA")
  (net 8 "LORA_SPI_SCK")
  (net 9 "LORA_SPI_MOSI")
  (net 10 "LORA_SPI_MISO")
  (net 11 "CM4_UART_TX")
  (net 12 "CM4_UART_RX")
  (gr_rect (start 0 0) (end 100 80) (layer "Edge.Cuts") (width 0.1) (fill none))
  (gr_rect (start 6 8) (end 28 32) (layer "Dwgs.User") (width 0.15) (fill none))
  (gr_rect (start 31 8) (end 62 42) (layer "Dwgs.User") (width 0.15) (fill none))
  (gr_rect (start 66 8) (end 94 25) (layer "Dwgs.User") (width 0.15) (fill none))
  (gr_rect (start 7 48) (end 31 72) (layer "Dwgs.User") (width 0.15) (fill none))
  (gr_rect (start 39 49) (end 76 73) (layer "Dwgs.User") (width 0.15) (fill none))
  (gr_rect (start 79 45) (end 94 67) (layer "Dwgs.User") (width 0.15) (fill none))
  (gr_text "Forest Rover Rev A" (at 9 9) (layer "F.SilkS"))
  (gr_text "100 mm x 80 mm board outline" (at 9 13) (layer "F.SilkS"))
  (gr_text "Power Stage" (at 11 12) (layer "Dwgs.User"))
  (gr_text "Solar input, charger, 5V buck, 3.3V LDO" (at 8 17) (layer "Dwgs.User"))
