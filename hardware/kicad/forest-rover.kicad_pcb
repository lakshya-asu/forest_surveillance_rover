  (gr_text "RF Edge Section" (at 70 12) (layer "Dwgs.User"))
  (gr_text "RFM95W, PI match, SMA edge connector" (at 67 17) (layer "Dwgs.User"))
  (gr_text "Analog Front-End" (at 10 53) (layer "Dwgs.User"))
  (gr_text "PIR conditioning and thermistor ADC path" (at 8 58) (layer "Dwgs.User"))
  (gr_text "Motor Driver Zone" (at 47 54) (layer "Dwgs.User"))
  (gr_text "DRV8871 x2, stitching vias, local bulk caps" (at 41 59) (layer "Dwgs.User"))
  (gr_text "CM4 / External I O" (at 80 50) (layer "Dwgs.User"))
  (gr_text "UART, I2C, USB-C, JST sensor headers" (at 79 55) (layer "Dwgs.User"))
  (gr_text "Keep switching regulators away from analog front-end" (at 6 39) (layer "Cmts.User"))
