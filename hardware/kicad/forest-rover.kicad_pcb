(kicad_pcb
  (version 20221018)
  (generator "codex")
  (general
    (thickness 1.6))
  (paper "A3")
  (title_block
    (title "Forest Surveillance Rover Main Controller PCB")
    (company "Team Onyx India")
    (rev "A"))
  (layers
    (0 "F.Cu" signal)
    (31 "B.Cu" signal)
    (32 "B.Adhes" user)
    (33 "F.Adhes" user)
    (34 "B.Paste" user)
    (35 "F.Paste" user)
    (36 "B.SilkS" user)
    (37 "F.SilkS" user)
    (38 "B.Mask" user)
    (39 "F.Mask" user)
    (40 "Dwgs.User" user)
    (41 "Cmts.User" user)
    (44 "Edge.Cuts" user)
    (45 "Margin" user)
    (46 "B.CrtYd" user)
    (47 "F.CrtYd" user)
    (48 "B.Fab" user)
    (49 "F.Fab" user)
    (4 "In1.Cu" power)
    (5 "In2.Cu" power))
  (setup
    (pad_to_mask_clearance 0)
    (pcbplotparams
      (layerselection 0x00010fc_ffffffff)
      (plot_on_all_layers_selection 0x0000000_00000000)
      (disableapertmacros false)))
  (net 0 "")
  (gr_rect (start 0 0) (end 100 80) (layer "Edge.Cuts") (width 0.1) (fill none))
  (gr_text "Forest Rover Rev A" (at 10 10) (layer "F.SilkS"))
  (gr_text "4-layer placeholder layout scaffold" (at 10 14) (layer "F.SilkS"))
  (gr_text "Keep RF section on right board edge" (at 64 10) (layer "Dwgs.User"))
  (gr_text "Buck + solar charger floorplan on left edge" (at 8 22) (layer "Dwgs.User"))
  (gr_text "Analog sensor front-end isolated in lower-left quadrant" (at 8 66) (layer "Dwgs.User"))
  (gr_text "Motor driver zone with stitching vias along lower edge" (at 48 68) (layer "Dwgs.User"))
  (gr_circle (center 4 4) (end 5.6 4) (layer "Edge.Cuts") (width 0.1) (fill none))
  (gr_circle (center 96 4) (end 97.6 4) (layer "Edge.Cuts") (width 0.1) (fill none))
  (gr_circle (center 4 76) (end 5.6 76) (layer "Edge.Cuts") (width 0.1) (fill none))
  (gr_circle (center 96 76) (end 97.6 76) (layer "Edge.Cuts") (width 0.1) (fill none))
)
